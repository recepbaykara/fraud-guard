            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_shadow_high_risk\",\n  \"amount\": 999999,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\",\n  \"merchant_id\": \"merchant_shadow\",\n  \"account_age_days\": 1,\n  \"user_age\": 19\n}"
            },
            "description": "High-risk transaction must NOT be blocked in shadow mode."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Shadow mode allows high-risk tx (200)', () => pm.response.to.have.status(200));",
                  "pm.test('Mode header is shadow', () => {",
                  "  pm.expect(pm.response.headers.get('x-fraud-mode')).to.equal('shadow');",
                  "});",
                  "pm.test('Would-block header is true', () => {",
                  "  pm.expect(pm.response.headers.get('x-fraud-would-block')).to.equal('true');",
                  "});",
                  "pm.test('Shadow decision is blocked', () => {",
                  "  pm.expect(pm.response.headers.get('x-fraud-shadow-decision')).to.equal('blocked');",
                  "});",
                  "pm.test('Fraud score is high', () => {",
                  "  pm.expect(parseInt(pm.response.headers.get('x-fraud-score'))).to.be.at.least(70);",
                  "});"
                ]
              }
            }
          ]
        },

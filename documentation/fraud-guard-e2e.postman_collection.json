    {
      "name": "06 — Edge Cases & Security",
      "description": "Input validation, security protections and edge cases.",
      "item": [
        {
          "name": "06-01 Negative Amount — Clipped to 0",
          "request": {
            "method": "POST",
            "url": "{{kong_url}}/fraud-test/post",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "x-api-key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_negative_amount\",\n  \"amount\": -99999,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\",\n  \"merchant_id\": \"merchant_neg\",\n  \"account_age_days\": 365,\n  \"user_age\": 30\n}"
            },
            "description": "Negative amounts are clipped to 0 by the extractor, so the transaction is treated as a zero-amount request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Negative amount request processed (not 500)', () => {",
                  "  pm.expect(pm.response.code).to.not.equal(500);",
                  "});",
                  "pm.test('fraud-guard handled the request', () => {",
                  "  pm.expect(pm.response.headers.get('x-fraud-score')).to.not.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "06-02 Missing user_id — fail-open → HTTP 200",
          "request": {
            "method": "POST",
            "url": "{{kong_url}}/fraud-test/post",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "x-api-key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\"\n}"
            },
            "description": "With fail_mode:open, missing user_id allows the request through."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing user_id with fail-open returns 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "06-03 SSRF Webhook — Private IP Blocked at Runtime",
          "request": {
            "method": "PATCH",
            "url": "{{kong_admin_url}}/plugins/{{plugin_id}}",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"config\": {\n    \"webhook_url\": \"http://192.168.1.100/hook\",\n    \"alert_on_block\": true\n  }\n}"
            },
            "description": "Set a private IP as webhook_url. The SSRF guard must skip the call at runtime (check Kong logs for 'Webhook skipped')."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Config accepted (SSRF check is runtime)', () => pm.response.to.have.status(200));",
                  "pm.test('Webhook URL saved', () => {",
                  "  pm.expect(pm.response.json().config.webhook_url).to.equal('http://192.168.1.100/hook');",
                  "});",
                  "pm.test('NOTE: Verify Kong DP logs for \"Webhook skipped — unsafe URL\"', () => pm.expect(true).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "06-04 SSRF Webhook — Trigger & Verify Skipped",
          "request": {
            "method": "POST",
            "url": "{{kong_url}}/fraud-test/post",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "x-api-key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_ssrf_trigger\",\n  \"amount\": 999999,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\",\n  \"merchant_id\": \"merchant_ssrf\",\n  \"account_age_days\": 1,\n  \"user_age\": 19\n}"
            },
            "description": "Trigger a block to invoke the webhook. SSRF guard must skip sending."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('High-risk tx blocked as expected', () => pm.response.to.have.status(403));",
                  "pm.test('NOTE: Check DP logs — should see \"Webhook skipped — unsafe URL\"', () => pm.expect(true).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "06-05 Clear SSRF Webhook",
          "request": {
            "method": "PATCH",
            "url": "{{kong_admin_url}}/plugins/{{plugin_id}}",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"config\": {\n    \"webhook_url\": null,\n    \"alert_on_block\": false\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Webhook cleared', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "06-06 Invalid UUID x-request-id — Regenerated",
          "request": {
            "method": "POST",
            "url": "{{kong_url}}/fraud-test/post",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "x-api-key", "value": "{{api_key}}"},
              {"key": "x-request-id", "value": "../../etc/passwd"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_bad_reqid\",\n  \"amount\": 100,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\",\n  \"merchant_id\": \"merchant_001\",\n  \"account_age_days\": 365,\n  \"user_age\": 30\n}"
            },
            "description": "Path-traversal string in x-request-id must be rejected; a fresh UUID is generated."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Bad request-id handled safely (not 500)', () => {",
                  "  pm.expect(pm.response.code).to.not.equal(500);",
                  "});",
                  "pm.test('Transaction ID is a valid UUID v4 (not the injection string)', () => {",
                  "  const txId = pm.response.headers.get('x-transaction-id') || '';",
                  "  pm.expect(txId).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i);",
                  "  pm.expect(txId).to.not.include('passwd');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "06-07 Schema Validation — review_score >= block_score → 400",
          "request": {
            "method": "PATCH",
            "url": "{{kong_admin_url}}/plugins/{{plugin_id}}",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"config\": {\n    \"thresholds\": {\n      \"block_score\": 30,\n      \"review_score\": 80\n    }\n  }\n}"
            },
            "description": "review_score (80) >= block_score (30) must be rejected by the schema validator."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid threshold config rejected (400)', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions review_score or block_score', () => {",
                  "  const body = pm.response.text();",
                  "  pm.expect(body).to.match(/review_score|block_score/i);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "07 — Response Headers Contract",
      "description": "Verify all expected response headers are present and correctly typed.",
      "item": [
        {
          "name": "07-01 All Headers Present on Allowed Tx",
          "request": {
            "method": "POST",
            "url": "{{kong_url}}/fraud-test/post",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "x-api-key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_headers_check\",\n  \"amount\": 100,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\",\n  \"merchant_id\": \"merchant_hdr\",\n  \"account_age_days\": 365,\n  \"user_age\": 30\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const headers = {",
                  "  'x-fraud-score':       pm.response.headers.get('x-fraud-score'),",
                  "  'x-risk-level':        pm.response.headers.get('x-risk-level'),",
                  "  'x-transaction-id':    pm.response.headers.get('x-transaction-id'),",
                  "  'x-execution-time-ms': pm.response.headers.get('x-execution-time-ms'),",
                  "  'x-fraud-mode':        pm.response.headers.get('x-fraud-mode'),",
                  "};",
                  "Object.entries(headers).forEach(([name, val]) => {",
                  "  pm.test(`Header ${name} is present`, () => pm.expect(val).to.not.be.null);",
                  "});",
                  "pm.test('x-fraud-score is a number 0-100', () => {",
                  "  const s = parseInt(headers['x-fraud-score']);",
                  "  pm.expect(s).to.be.at.least(0).and.at.most(100);",
                  "});",
                  "pm.test('x-risk-level is one of low/medium/high/whitelisted', () => {",
                  "  pm.expect(['low','medium','high','whitelisted']).to.include(headers['x-risk-level']);",
                  "});",
                  "pm.test('x-transaction-id is UUID v4', () => {",
                  "  pm.expect(headers['x-transaction-id']).to.match(",
                  "    /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i",
                  "  );",
                  "});",
                  "pm.test('x-fraud-mode is enforce or shadow', () => {",
                  "  pm.expect(['enforce','shadow']).to.include(headers['x-fraud-mode']);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "07-02 Blocked Tx Has Reference ID in Body",
          "request": {
            "method": "POST",
            "url": "{{kong_url}}/fraud-test/post",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "x-api-key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_ref_check\",\n  \"amount\": 999999,\n  \"currency\": \"TRY\",\n  \"transaction_type\": \"pos\",\n  \"merchant_id\": \"merchant_block\",\n  \"account_age_days\": 1,\n  \"user_age\": 19\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request blocked (403)', () => pm.response.to.have.status(403));",
                  "const body = pm.response.json();",
                  "pm.test('Response body has reference', () => {",
                  "  pm.expect(body).to.have.property('reference');",
                  "  pm.expect(body.reference).to.match(/^FRD-\\d{4}-\\d{2}-\\d{2}-\\d+$/);",
                  "});",
                  "pm.test('Response body has risk_score', () => {",
                  "  pm.expect(body).to.have.property('risk_score');",
                  "});",
                  "pm.test('Response body has message', () => {",
                  "  pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
